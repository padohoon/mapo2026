# Supabase 연결 (Project Settings → API 에서 확인)
# 이 파일을 복사해서 .env.local 로 저장한 뒤 값을 채우세요. (.env.local 은 git 에 커밋되지 않음)
#
# ⚠️ SERVICE_ROLE 키는 서버 전용 비밀키입니다. 절대 공유/커밋하지 마세요.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 팀 공용 비밀번호 (4단계 인증에서 사용)
APP_PASSWORD=set-a-strong-password
